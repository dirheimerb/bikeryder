# Copy to `.env` and fill in. `.env` is gitignored.
#
# Supabase — from your project's API settings (Project Settings → API).
# Use the project URL and the publishable/anon key (safe for client apps; RLS enforces access).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Google Maps key for Android builds (iOS uses Apple Maps, no key needed).
# Create at https://console.cloud.google.com/ → Maps SDK for Android.
GOOGLE_MAPS_ANDROID_API_KEY=
